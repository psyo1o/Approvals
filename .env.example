# ── 애플리케이션 ──
APP_SECRET=change-me-long-random
APP_ADMIN_ID=admin
APP_ADMIN_PW=admin1234!
APP_DATA_DIR=./data

# ── 데이터베이스 (미설정 시 SQLite ./data/app.db) ──
# DATABASE_URL=sqlite:////data/app.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/approval
# DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/approval?charset=utf8mb4

# ── 세션 (Phase 6.1) ──
SESSION_IDLE_SECONDS=7200
SESSION_ABSOLUTE_SECONDS=2592000

# ── IP 허용 (비우면 제한 없음, 콤마 구분) ──
# ALLOWED_IPS=127.0.0.1,192.168.10.*,10.0.0.0/8
# TRUST_PROXY=1

# ── 출장복명서 (부서명 접두사: 관리팀·측정팀 등 일치) ──
# TRIP_REPORT_APPROVAL_DEPTS=관리,측정
# TRIP_REPORT_WRITER_DEPTS=관리,측정

# ── 업무일지 작성 제외 직급 (콤마 구분, is_admin 과 무관) ──
# WORK_LOG_EXEMPT_GRADES=관리자
# WORK_LOG_MIN_APPROVER_GRADE=차장
# WORK_LOG_MAX_APPROVER_GRADE=대표

# ── 휴가·외출 연차 환산 (근무 8.5h = 연차 1일, 외출 기본 30분) ──
# WORK_DAY_HOURS=8.5
# OUTING_UNIT_MINUTES=30
# OUTING_LEAVE_KIND_NAME=외출

# ── Phase 7 멀티 지사 ──
# 전 지사 결재 후보(대표 이상). 헤더 「조회」 전환: 관리자 + 원주본사(WJ) 대표 이상만 (제천 대표 제외).
# CROSS_BRANCH_REP_GRADE_NAME=대표
# 결재 문서는 상신자 branch_id 로 WJ/JC 분리. 업무일지: 평일 전원·주말 근무자, 결재 차장~대표(지사별).
# QUALITY_NAS_ROOT_WONJU=/nas_quality_wonju
# QUALITY_NAS_ROOT_JECHEON=/nas_quality_jecheon

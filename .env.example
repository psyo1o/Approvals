# ── 애플리케이션 ──
APP_SECRET=change-me-long-random
APP_ADMIN_ID=admin
APP_ADMIN_PW=admin1234!
APP_DATA_DIR=./data

# ── 데이터베이스 (미설정 시 SQLite ./data/app.db) ──
# DATABASE_URL=sqlite:////data/app.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/approval
# DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/approval?charset=utf8mb4

# ── 세션 (Phase 6.1) ──
SESSION_IDLE_SECONDS=7200
SESSION_ABSOLUTE_SECONDS=2592000

# ── IP 허용 (비우면 제한 없음, 콤마 구분) ──
